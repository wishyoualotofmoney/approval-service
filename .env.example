# Copy to .env for local runs. docker-compose sets these on its own.

APP_NAME=approval-service
ENVIRONMENT=local
LOG_LEVEL=INFO

# Local default: SQLite (no external services needed).
DATABASE_URL=sqlite+aiosqlite:///./approval.db

# PostgreSQL example (used by docker-compose):
# DATABASE_URL=postgresql+asyncpg://approval:approval@db:5432/approval
